@model ShipwayUnitOfWork.Models.Users
@using ShipwayUnitOfWork.Models
<div class="modal-header">
    <button aria-hidden="true" data-dismiss="modal" class="close" type="button">×</button>
    <h4 class="modal-title">Sửa tài khoản</h4>
</div>
@using (Html.BeginForm("EditAccount", "SuperAdmin", FormMethod.Post, new { @class = "form-horizontal" }))
{
    <div class="modal-body">

        @Html.ValidationSummary(true)
        <div class="form-horizontal">
            <div class="form-group">
                <label class="col-lg-3 col-sm-3 control-label">Tên đăng nhập *</label>
                <div class="col-lg-9">
                    @Html.HiddenFor(model => model.Id)
                    @Html.TextBoxFor(model => model.UserName, new { @class = "form-control", @required = "required" })
                </div>
            </div>
            <div class="form-group">
                <label class="col-lg-3 col-sm-3 control-label">Tên</label>
                <div class="col-lg-9">
                    @Html.TextBoxFor(model => model.Name, new { @class = "form-control" })
                </div>
            </div>
            <div class="form-group">
                <label for="txtFirstName" class="col-lg-3 col-sm-3 control-label">Email *</label>
                <div class="col-lg-9">
                    @Html.TextBoxFor(model => model.Email, new { @class = "form-control", @required = "required", @type = "email" })
                </div>
            </div>
            <div class="form-group">
                <label class="col-lg-3 col-sm-3 control-label">Số điện thoại *</label>
                <div class="col-lg-9">
                    @Html.TextBoxFor(model => model.PhoneNumber, new { @class = "form-control", @required = "required" })
                </div>
            </div>
            <div class="form-group">
                <label class="col-lg-3 col-sm-3 control-label">Loại tài khoản *</label>
                <div class="col-lg-9">
                    @Html.DropDownListFor(model => model.TypeId, new SelectList(ViewBag.Permission, "TypeId", "TypeName"), "-----Lựa chọn quyền truy cập----", new { @id = "PermissionId", @class = "types-user form-control m-bot15 " })
                </div>
            </div>
            <div class="form-group adminAgency" style="">
                <label class="col-lg-3 control-label">Trực thuộc đại lý</label>
                <div class="col-lg-9">
                    @Html.DropDownListFor(model => model.AgencyId, new SelectList(ViewBag.ListAgency, "AgencyId", "AgencyName", "----Lựa chọn đại lý----"), new { @class = "form-control m-bot15" })
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <div class="form-group">
            <div class="col-lg-offset-2 col-lg-10">
                <button type="submit" class="btn-luu btn btn-default btn-primary">Lưu</button>
            </div>
        </div>
    </div>
}

@section scripts {
    
    
} 