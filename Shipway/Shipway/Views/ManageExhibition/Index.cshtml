@model IEnumerable<ShipwayUnitOfWork.Models.ModelView.ExhibitionModelView>
@using ShipwayUnitOfWork.Helper
@{
    ViewBag.Title = "Index";
    
}

<div class="row">
    <div class="col-sm-12">
        <section class="panel">
            <header class="panel-heading">

                <h4>
                    QUẢN LÝ ĐƠN HÀNG
                    <a href="#" class="popover-help" data-original-title="Equipment Report" data-content="">
                        <i class="fa fa-question-circle"></i>
                    </a>
                </h4>
                <span class="tools pull-right">
                    <a href="javascript:;" class="fa fa-chevron-down"></a>
                </span>
            </header>
            <div class="panel-body">

                @using (Html.BeginForm("Index", "ManageExhibition"))
                {
                    <div class="row" style="text-align:center;">
                        <div class="col-lg-3">
                            <input name="ExhibitionId" value="@ViewBag.ExhibitionId" type="text" class="form-control" placeholder="Mã đơn..."/>
                        </div>
                        <div class="col-lg-3">
                            @Html.DropDownList("AgencyId", new SelectList(ViewBag.ListAgency, "AgencyId", "AgencyName"), "Tất cả đại lý", new { @class = "form-control m-bot15 " })
                        </div>
                        <div class="col-lg-3">
                            @Html.DropDownList("ExhibitionStatusId", new SelectList(ViewBag.ExhibitionStatus, "ExhibitionStatusId", "Name"), "Tất cả trạng thái", new { @class = "form-control m-bot15 " })
                        </div>
                        <div class="col-lg-2">
                            <button type="submit" class="btn btn-success"> Xem đơn hàng </button>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
</div>

