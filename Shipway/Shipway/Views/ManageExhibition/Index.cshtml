                <div class="adv-table">
                    <table class="display table listExhibition">
                        <thead>
                            <tr>
                                <th width="100px">Mã đơn hàng</th>
                                <th>Người gửi</th>
                                <th>SĐT người gửi</th>
                                <th>Người nhận</th>
                                <th>SĐT người nhận</th>
                                <th>Địa chỉ nhận</th>
                                <th>Phí vận chuyển</th>
                                <th>Ngày giao dự kiến</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody id="tableContent">
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <th>@item.ExhibitionId</th>
                                    <td>@Utils.SummaryString(item.SenderUser.Name)</td>
                                    <td>@item.SenderUser.PhoneNumber</td>
                                    <td>@Utils.SummaryString(item.ReceiverName)</td>
                                    <td>@item.ReceiverPhoneNumber</td>
                                    <td>@Utils.SummaryString(@item.ReceiverAddress)</td>
                                    <td>@item.Cost</td>
                                    <td >@Convert.ToDateTime(@item.DayReceive == null ? DateTime.Now : @item.DayReceive).ToString("dd/MM/yyyy")</td>
                                    <td>@Utils.SummaryString(item.ExhibitionStatus.Name)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
